# ─────────────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
backend/.venv/          # explicit - virtual env lives here
*.egg-info/
dist/
build/

# ─────────────────────────────────────────────────────────────────────────────
# Environment & Secrets — NEVER commit these
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.*
backend/.env
backend/.env.*          # covers .env.local, .env.production etc
frontend/.env.local
frontend/.env.production

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
backend/portfolio.db
backend/*.db            # catches any other sqlite files created later
*.db-shm                # SQLite WAL shared memory file
*.db-wal                # SQLite WAL write-ahead log

# ─────────────────────────────────────────────────────────────────────────────
# Node / Frontend
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/         # Vite dev cache — can be hundreds of MB

# ─────────────────────────────────────────────────────────────────────────────
# SSL / Keys (if you add HTTPS later)
# ─────────────────────────────────────────────────────────────────────────────
*.pem
*.key
*.crt
*.cert

# ─────────────────────────────────────────────────────────────────────────────
# Editor
# ─────────────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ─────────────────────────────────────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pip-log.txt